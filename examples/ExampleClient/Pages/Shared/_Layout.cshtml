<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — White Rabbit Example Client</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; color: #1a1a1a; }
        nav { display: flex; gap: 1.5rem; align-items: center; border-bottom: 1px solid #ddd; padding-bottom: 0.75rem; margin-bottom: 2rem; }
        nav a { text-decoration: none; color: #0066cc; }
        nav .user { margin-left: auto; font-size: 0.875rem; color: #555; }
        nav form { margin: 0; }
        nav button { background: none; border: 1px solid #ccc; padding: 0.25rem 0.75rem; border-radius: 4px; cursor: pointer; font-size: 0.875rem; }
        h1 { margin-top: 0; }
        table { border-collapse: collapse; width: 100%; }
        th, td { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee; }
        th { background: #f5f5f5; font-weight: 600; }
        .badge { display: inline-block; background: #e8f4e8; color: #2d6a2d; border-radius: 3px; padding: 0.1rem 0.4rem; font-size: 0.75rem; }
        .error { background: #fff3f3; border: 1px solid #f5a0a0; padding: 1rem; border-radius: 4px; }
        pre { background: #f5f5f5; padding: 1rem; border-radius: 4px; overflow-x: auto; font-size: 0.8rem; }
        .btn { display: inline-block; background: #0066cc; color: white; padding: 0.5rem 1.25rem; border-radius: 4px; text-decoration: none; font-size: 0.9rem; }
    </style>
</head>
<body>
    <nav>
        <strong>White Rabbit Example Client</strong>
        <a href="/">Home</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a href="/pull-zones">Pull Zones</a>
            <span class="user">@User.Identity.Name</span>
            <form method="post" action="/logout">
                <button type="submit">Sign out</button>
            </form>
        }
        else
        {
            <a href="/pull-zones">Sign in</a>
        }
    </nav>

    @RenderBody()
</body>
</html>
