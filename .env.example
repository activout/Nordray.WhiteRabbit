# Copy this file to .env and fill in real values for local development.
# .env is git-ignored and never committed.
#
# All WhiteRabbit_ variables are loaded by AddEnvironmentVariables(prefix: "WhiteRabbit_").
# The prefix is stripped and __ maps to : in the config hierarchy.
# Example: WhiteRabbit_Mailjet__ApiKey  →  Mailjet:ApiKey

# Dex OIDC client secret — shared between Dex and White Rabbit.
# Dex reads this via $DEX_WHITE_RABBIT_CLIENT_SECRET substitution in deploy/dex/config.yaml.
# White Rabbit reads it via WhiteRabbit_Dex__ClientSecret.
# Both are sourced from the same variable so you only set it once.
DEX_WHITE_RABBIT_CLIENT_SECRET=change-me-in-production
WhiteRabbit_Dex__ClientSecret=${DEX_WHITE_RABBIT_CLIENT_SECRET}

# Example client OIDC secret (used by both Dex and the example-client container)
DEX_EXAMPLE_CLIENT_SECRET=example-client-dev-secret

# Mailjet (leave empty to use SMTP/Mailpit fallback in dev)
WhiteRabbit_Mailjet__ApiKey=
WhiteRabbit_Mailjet__SecretKey=
WhiteRabbit_Mailjet__FromEmail=noreply@example.com
